# CareAttend backend — environment configuration sample.
# Copy to `.env` and fill in real values. NEVER commit a real .env.

# Session/signing key. REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-hex-string

# SQLAlchemy database URL.
#   PostgreSQL: postgresql+psycopg://USER:PASSWORD@HOST:5432/careattend
#   SQLite (dev/tests): sqlite:////tmp/careattend.sqlite
DATABASE_URL=postgresql+psycopg://localhost:5432/careattend

# CORS allowlist — comma-separated origins, or "*" for dev only.
CORS_ORIGINS=*

# Flask debug. MUST be 0 in production (1 exposes the Werkzeug RCE debugger).
FLASK_DEBUG=0

# Local/demo only. MUST stay 0 in production; when 1, password-reset OTPs are
# returned in API responses if SMTP is not configured.
RESET_DEV_CODE=0

# Dev server port (gunicorn binds its own --bind in production).
PORT=5000
